modules = ["nodejs-20", "java-graalvm22.3", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd CubeTale-DiscordCHAT && mvn package -B --no-transfer-progress -q && echo '✓ CubeTale-DiscordCHAT built successfully' && cd ../CubeTale-InteractiveChat-Addon && mvn package -B --no-transfer-progress -q && echo '✓ CubeTale-InteractiveChat-Addon built successfully' && cd ../CubeTale-Events && mvn package -B --no-transfer-progress -q && echo '✓ CubeTale-Events built successfully' && echo '' && echo '--- All plugin JARs ready ---' && ls -lh ../CubeTale-DiscordCHAT/target/*.jar ../CubeTale-InteractiveChat-Addon/target/*.jar ../CubeTale-Events/target/*.jar"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "autoscale"
run = ["node", "artifacts/api-server/dist/index.cjs"]
build = ["pnpm", "run", "build"]
